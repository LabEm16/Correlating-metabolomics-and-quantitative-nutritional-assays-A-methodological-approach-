Step #2: Carbs (TNC, NDF, ADF, ADL, Sugars) Correlation scaled/log & CGYL
```{r}
shikimates_full <- read.csv("PSM Data/Correlation/Shikimates.csv")
carbs_full <- read.csv("PSM Data/Correlation/Carbs.csv")

nutrient_list <- list(
  list(df = CGYL_tnc,    col = "TNC",    dataset = "CGYL"),
  list(df = CGML_tnc,    col = "TNC",    dataset = "CGML"),
  list(df = CGYL_ndf,    col = "NDF",    dataset = "CGYL"),
  list(df = CGML_ndf,    col = "NDF",    dataset = "CGML"),
  list(df = CGYL_adf,    col = "ADF",    dataset = "CGYL"),
  list(df = CGML_adf,    col = "ADF",    dataset = "CGML"),
  list(df = CGYL_adl,    col = "ADL",    dataset = "CGYL"),
  list(df = CGML_adl,    col = "ADL",    dataset = "CGML"),
  list(df = CGYL_Sugar,  col = "Sugar",  dataset = "CGYL"),
  list(df = CGML_Sugar,  col = "Sugar",  dataset = "CGML"),
  list(df = CGYL_Starch, col = "Starch", dataset = "CGYL"),
  list(df = CGML_Starch, col = "Starch", dataset = "CGML")
)

results <- data.frame(
  Dataset  = character(),
  SubGroup = character(),
  Measure  = character(),
  N        = integer(),
  rho      = numeric(),
  R2       = numeric(),
  p_value  = numeric(),
  stringsAsFactors = FALSE
)

for (item in nutrient_list) {
  
  merged_data <- merge(carbs_full, item$df,
                       by.x = "NPC.pathway",
                       by.y = "PSM_match")
  
  if (nrow(merged_data) == 0) next
  
  merged_data$Carbohydrates_log <- log1p(merged_data$Carbohydrates)
  
  correlation_test <- cor.test(
    merged_data$Carbohydrates_log,
    merged_data[[item$col]],
    method = "spearman",
    use = "complete.obs",
    exact = FALSE
  )
  
  rho_val <- unname(correlation_test$estimate)
  
  results <- rbind(results, data.frame(
    Dataset  = "carbs_full",
    SubGroup = item$dataset,
    Measure  = item$col,
    N        = sum(complete.cases(merged_data$Carbohydrates_log,
                                  merged_data[[item$col]])),
    rho      = rho_val,
    R2       = rho_val^2,
    p_value  = correlation_test$p.value
  ))
}

for (item in nutrient_list) {
  
  merged_data <- merge(shikimates_full, item$df,
                       by.x = "NPC.pathway",
                       by.y = "PSM_match")
  
  if (nrow(merged_data) == 0) next
  
  merged_data$Shikimates_log <- log1p(merged_data$Shikimates)
  
  correlation_test <- cor.test(
    merged_data$Shikimates_log,
    merged_data[[item$col]],
    method = "spearman",
    use = "complete.obs",
    exact = FALSE
  )
  
  rho_val <- unname(correlation_test$estimate)
  
  results <- rbind(results, data.frame(
    Dataset  = "shikimates_full",
    SubGroup = item$dataset,
    Measure  = item$col,
    N        = sum(complete.cases(merged_data$Shikimates_log,
                                  merged_data[[item$col]])),
    rho      = rho_val,
    R2       = rho_val^2,
    p_value  = correlation_test$p.value
  ))
}
wb <- createWorkbook()

dataset_labels <- c(
  carbs_full      = "carbs_full",
  shikimates_full = "shik_full"
)
for (subgroup in c("CGYL", "CGML")) {
  for (dataset in names(dataset_labels)) {
    tab_name   <- paste0(subgroup, "_", dataset_labels[[dataset]])
    sheet_data <- results[results$SubGroup == subgroup & results$Dataset == dataset, ]
    addWorksheet(wb, tab_name)
    writeData(wb, tab_name, sheet_data)
  }
}

saveWorkbook(wb, "Carbs_Shikimates_Correlation_Results.xlsx", overwrite = TRUE)
