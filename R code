Step 5: Graphs 
```{r}
plot_sig_corr <- function(data, xvar, yvar, xlab, ylab) {
  cor_test <- cor.test(data[[xvar]], data[[yvar]],
                       use = "complete.obs",
                       method = "spearman",
                       exact = FALSE)
  rho_val <- round(unname(cor_test$estimate), 2)
  r2_val  <- round(unname(cor_test$estimate)^2, 2)
  p_val <- signif(cor_test$p.value, 2)
  p_text <- ifelse(p_val < 0.001, "p < 0.001", paste0("p = ", p_val))
  
  ggplot(data, aes(x = .data[[xvar]], y = .data[[yvar]])) +
    geom_point(size = 3, color = "#336B87") +
    geom_smooth(method = "lm", se = TRUE, color = "#763626") +
    labs(x = xlab, y = ylab) +
    geom_label(
      aes(x = -Inf, y = Inf,
          label = paste0("rho = ", rho_val, ", R\u00B2 = ", r2_val, ", ", p_text)),
      hjust = -0.05,
      vjust = -0.6,
      size = 5,
      fill = "white",
      color = "black",
      linewidth = 0,
      inherit.aes = FALSE
    ) +
    coord_cartesian(clip = "off") +
    theme_classic(base_size = 12) +
    theme(
      plot.margin = ggplot2::margin(t = 18, r = 5, b = 5, l = 5)
    )
}

make_plots <- function(ndf, adf, adl, sugar, cp, ap, fat,
                       carbs_psm, shikimates_psm, protein_psm, fat_psm) {
  
  p_NDF <- {
