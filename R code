get_corr_stats <- function(data, xvar, yvar, measure_label) {
  cor_test <- cor.test(data[[xvar]], data[[yvar]],
                       use = "complete.obs", method = "spearman", exact = FALSE)
  rho_val <- unname(cor_test$estimate)
  
  data.frame(
    Measure = measure_label,
    N       = sum(complete.cases(data[[xvar]], data[[yvar]])),
    rho     = round(rho_val, 3),
    R2      = round(rho_val^2, 3),
    p_value = cor_test$p.value,
    stringsAsFactors = FALSE
  )
}

