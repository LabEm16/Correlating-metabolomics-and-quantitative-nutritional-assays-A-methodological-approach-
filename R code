    df$Prot <- log1p(df$Amino.acids.and.Peptides)
    plot_sig_corr(df, "CP", "Prot", "Crude Protein", "Amino acids & Peptides")
  }
  
  p_AP <- {
    df <- merge(protein_psm, ap, by.x = "NPC.pathway", by.y = "PSM_match")
    df$Prot <- log1p(df$Amino.acids.and.Peptides)
    df$APx  <- df$AP
